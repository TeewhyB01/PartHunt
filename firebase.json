{
  "hosting": {
    "public": ".",
    "rewrites": [
      {
        "source": "/api/vehicle-lookup",
        "function": {
          "functionId": "vehicleLookup",
          "region": "europe-west2"
        }
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  }
}
